---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings } = Astro.props;
const toc = buildToc(headings);

export interface Heading {
  depth: number;
  slug: string;
  text: string;
  subheadings: Heading[];
}

function buildToc(headings: Heading[]) {
  const toc: Heading[] = [];
  const parentHeadings = new Map<number, Heading>();
  headings.forEach((h) => {
    const heading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    if (heading.depth === 2) {
      toc.push(heading);
    } else {
      parentHeadings.get(heading.depth - 1)?.subheadings.push(heading);
    }
  });
  return toc;
}
---

<details class="toc" open>
  <summary><span class="caret">▶</span> Table of Contents</summary>
  <ol>
    {toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
  </ol>
</details>

<style is:global>
  .toc {
    margin: 30px 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--card);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .toc > summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 18px;
    font-size: calc(14px * var(--fsm));
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 9px;
    background: var(--chip-bg);
  }
  .toc > summary::-webkit-details-marker {
    display: none;
  }
  .toc > summary .caret {
    transition: transform 0.2s;
    color: var(--mut);
    font-size: 11px;
  }
  .toc[open] > summary .caret {
    transform: rotate(90deg);
  }
  .toc ol {
    margin: 6px 0;
    padding: 8px 18px 14px 36px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .toc ol ol {
    margin: 8px 0 0;
    padding: 0 0 0 18px;
  }
  .toc li {
    font-size: calc(14px * var(--fsm));
  }
  .toc a {
    color: var(--mut);
    text-decoration: none;
    transition: color 0.15s;
  }
  .toc a:hover {
    color: var(--accent-text);
  }
  .toc a.active {
    color: var(--accent-text);
    font-weight: 600;
  }
</style>

<script>
  // Scroll-spy: highlight the ToC link for the section currently in view. The
  // "current" heading is the last one whose top has scrolled past a trigger
  // line just below the sticky nav.
  let teardown: (() => void) | null = null;

  function initTocSpy() {
    teardown?.();
    teardown = null;

    const toc = document.querySelector<HTMLElement>(".toc");
    if (!toc) return;
    // Hidden on narrow screens — nothing to highlight.
    if (toc.offsetParent === null) return;

    const links = [...toc.querySelectorAll<HTMLAnchorElement>("a[href^='#']")];
    if (links.length === 0) return;

    const linkById = new Map<string, HTMLAnchorElement>();
    for (const link of links) {
      const id = decodeURIComponent(link.hash.slice(1));
      if (id) linkById.set(id, link);
    }

    const headings = [...linkById.keys()]
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);
    if (headings.length === 0) return;

    let activeId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === activeId) return;
      activeId = id;
      for (const link of links) link.classList.remove("active");
      if (id) linkById.get(id)?.classList.add("active");
    };

    const update = () => {
      const triggerY = 100;
      let current = headings[0].id;
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= triggerY) current = h.id;
        else break;
      }
      setActive(current);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    update();
    teardown = () => window.removeEventListener("scroll", onScroll);
  }

  document.addEventListener("astro:page-load", initTocSpy);
  initTocSpy();
</script>
