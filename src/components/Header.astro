---
const path = Astro.url.pathname;

const isActive = (prefix: string) =>
  prefix === "/" ? path === "/" : path.startsWith(prefix);
---

<header class="nav" transition:persist>
  <a class="brand" href="/" aria-label="drew's dev blog home">
    <span class="mark" id="brandMark"></span>
    <span class="word">
      drew.silcock<span class="tld">.dev</span>
      <span class="caret"></span>
    </span>
  </a>
  <span class="spacer"></span>
  <nav class="nav-links">
    <a href="/" class:list={[isActive("/") && "active"]}>home</a>
    <a href="/blog" class:list={[isActive("/blog") && "active"]}>blog</a>
    <a href="/projects" class:list={[isActive("/projects") && "active"]}>
      projects
    </a>
    <a href="/about" class:list={[isActive("/about") && "active"]}>about</a>
  </nav>
  <div class="controls">
    <div class="ctl-group" role="group" aria-label="Text size">
      <button class="ctl-btn fs-s" data-fs="s" title="Small text">A</button>
      <button class="ctl-btn fs-m" data-fs="m" title="Medium text">A</button>
      <button class="ctl-btn fs-l" data-fs="l" title="Large text">A</button>
    </div>
    <div class="ctl-group" role="group" aria-label="Theme">
      <button class="ctl-btn" id="themeToggle" aria-label="Theme"></button>
    </div>
    <button class="search" id="magnifying-glass" title="Search">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.2-3.2"></path>
      </svg>
      Search <span class="kbd">⌘K</span>
    </button>
  </div>
</header>
