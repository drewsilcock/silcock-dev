---
import Layout from "@layouts/Layout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { HOME, SITE } from "@consts";
import {
  shouldListPage,
  readingTime,
  displayViews,
  displayStars,
} from "@lib/utils";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allPosts = (await getCollection("blog"))
  .filter(shouldListPage)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPosts = allPosts.length;
const posts = allPosts.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
)
  .filter(shouldListPage)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const tagSet = new Set(allPosts.flatMap((post) => post.data.tags ?? []));
const topicLabels = [
  "Go",
  "Rust",
  "React",
  "Svelte",
  "TypeScript",
  "Python",
  "Postgres",
  "Best practices",
];
const topics = topicLabels.map((label) => {
  const slug = label.toLowerCase();
  return { label, href: tagSet.has(slug) ? `/blog/tags/${slug}` : "/blog" };
});
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION} route="index">
  <section class="hero">
    <span class="hi">👋 hey, I'm Drew</span>
    <h1>
      I write deep dives into the parts of the stack most people skim past.
    </h1>
    <p class="lede">
      Software engineer in Liverpool. No courses, no funnels, no “hustle” — just
      databases, compilers and the occasional cursed git trick, explained
      properly.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="/blog">Read the latest →</a>
      <a class="btn btn-ghost" href="/rss.xml">Subscribe via RSS</a>
    </div>
    <div class="topics">
      {
        topics.map((topic) => (
          <a class="topic" href={topic.href}>
            {topic.label}
          </a>
        ))
      }
    </div>
  </section>

  <div class="sec-head">
    <h2>Latest posts</h2>
    <span class="spacer"></span>
    <a href="/blog">See all {totalPosts} →</a>
  </div>
  <section class="posts">
    {
      posts.map((post, i) => (
        <a class="post" href={`/blog/${post.slug}`}>
          <div class="post-top">
            <span class="post-num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="post-title">{post.data.title}</h3>
            <span class="post-arrow">→</span>
          </div>
          <p class="post-sub">{post.data.description}</p>
          <div class="post-meta">
            <span class="tags">
              {(post.data.tags ?? []).map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </span>
            <span class="spacer" />
            <span class="meta-bit">
              <FormattedDate date={post.data.date} />
            </span>
            <span class="meta-sep">·</span>
            <span class="meta-bit">{readingTime(post.body)}</span>
            <span class="meta-sep">·</span>
            <span class="meta-bit">{displayViews(post)} views</span>
          </div>
        </a>
      ))
    }
  </section>

  <div class="sec-head">
    <h2>Recent projects</h2>
    <span class="spacer"></span>
    <a href="/projects">See all →</a>
  </div>
  <section class="proj-grid">
    {
      projects.map((project) => (
        <a class="proj" href={`/projects/${project.slug}`}>
          <div class="proj-top">
            <span class="proj-dot" />
            <h4 class="proj-name">{project.data.title}</h4>
            <span class="spacer" />
            <span class="proj-stars">★ {displayStars(project)}</span>
          </div>
          <p class="proj-sub">{project.data.description}</p>
          <div class="tags">
            {(project.data.tags ?? []).map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        </a>
      ))
    }
  </section>

  <div class="contact">
    <div>
      <h3>Say hi 😎</h3>
      <p>Got a question or just want to chat? My inbox is open.</p>
    </div>
    <span class="spacer"></span>
    <a class="email" href={SITE.EMAIL} aria-label="Email Drew">
      <span class="email email-text">{SITE.EMAIL}</span>
    </a>
  </div>
</Layout>
