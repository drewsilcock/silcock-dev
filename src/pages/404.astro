---
import Layout from "@layouts/Layout.astro";
import { SITE } from "@consts";
---

<Layout title="404" description={SITE.DESCRIPTION} route="404">
  <div class="page-head">
    <h1 class="page-title">404 — page not found</h1>
    <p class="page-intro">
      That page doesn't exist, or it wandered off somewhere. Let's get you back
      to somewhere useful.
    </p>
  </div>
  <a class="backlink" href="/">‹ Back home</a>
</Layout>
