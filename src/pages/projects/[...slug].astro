---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import {
  iconForSocial,
  readingTime,
  shouldListPage,
  shouldRenderPage,
} from "@lib/utils";
import TableOfContents from "@components/TableOfContents.astro";
import PostStats from "@components/PostStats.astro";
import RepoStars from "@components/RepoStars.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter(shouldRenderPage)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content, headings } = await project.render();

const projects = (await getCollection("projects"))
  .filter(shouldListPage)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const projectIndex = projects.findIndex((p) => p.slug === project.slug);
const nextProject = projects[projectIndex + 1];

const links = [
  project.data.demoURL && { href: project.data.demoURL, text: "demo" },
  project.data.repoURL && { href: project.data.repoURL, text: "repo" },
  project.data.packageURL && { href: project.data.packageURL, text: "package" },
].filter(Boolean) as { href: string; text: string }[];

const tags = project.data.tags ?? [];
const socials = project.data.socials ?? [];
---

<Layout
  title={project.data.title}
  description={project.data.description}
  route={`${project.collection}/${project.slug}`}
  article={{
    title: project.data.title,
    publishedDate: project.data.date,
    updatedDate: project.data.updated,
    tags: project.data.tags,
  }}
>
  <a class="backlink" href="/projects">‹ Back to projects</a>

  <article class="post-grid">
    <aside class="post-aside">
      {headings.length > 0 && <TableOfContents headings={headings} />}
      <PostStats slug={`projects/${project.slug}`} />
      <span
        class="meta-stat live-stat live-rail"
        data-live
        data-slug={`projects/${project.slug}`}
        hidden
      >
        <span data-live-count></span>
      </span>
    </aside>

    <div class="post-main">
      <div class="article-head">
        <div class="article-meta">
          <span><FormattedDate date={project.data.date} /></span>
          <span class="sep">·</span>
          <span>{readingTime(project.body)}</span>
          <RepoStars repoURL={project.data.repoURL} />
          <span class="meta-stat" data-views-wrap hidden>
            <span class="sep">·</span>
            <span data-post-views></span>
          </span>
          <span
            class="meta-stat live-stat"
            data-live
            data-slug={`projects/${project.slug}`}
            hidden
          >
            <span data-live-count></span>
          </span>
        </div>
        <h1>{project.data.title}</h1>
        <div class="article-tags">
          {tags.map((tag) => <a href={`/projects/tags/${tag}`}>#{tag}</a>)}
          {
            (links.length > 0 || socials.length > 0) && tags.length > 0 && (
              <span class="repo" style="color:var(--dim)">
                ·
              </span>
            )
          }
          {
            links.map((link) => (
              <a class="repo" href={link.href} target="_blank" rel="noopener">
                {link.text}
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17 17 7M9 7h8v8" />
                </svg>
              </a>
            ))
          }
          {
            socials.length > 0 && (
              <>
                <span class="repo">Discuss on</span>
                {socials.toSorted().map((social) => (
                  <a
                    class="repo discuss-link"
                    href={social}
                    target="_blank"
                    rel="noopener"
                    aria-label="Discuss"
                  >
                    <span set:html={iconForSocial(social)} />
                  </a>
                ))}
              </>
            )
          }
        </div>
      </div>

      <div class="article">
        <Content />
      </div>

      <div class="article-foot">
        <div class="prevnext">
          <a class="pn prev" href="/projects">
            <span class="dir">‹ All projects</span>
            <span class="t">Back to the full list</span>
          </a>
          {
            nextProject && (
              <a class="pn next" href={`/projects/${nextProject.slug}`}>
                <span class="dir">Next project ›</span>
                <span class="t">{nextProject.data.title}</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </article>
</Layout>
