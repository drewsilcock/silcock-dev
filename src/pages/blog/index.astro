---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import PostCard from "@components/PostCard.astro";
import { BLOG } from "@consts";
import { shouldListPage } from "@lib/utils";

const posts = (await getCollection("blog"))
  .filter(shouldListPage)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tags = posts
  .flatMap((post) => post.data.tags ?? [])
  .filter((tag, index, self) => self.indexOf(tag) === index);

type Acc = {
  [year: string]: CollectionEntry<"blog">[];
};

const postsMap = posts.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsMap).sort((a, b) => parseInt(b) - parseInt(a));
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION} route="blog">
  <div class="page-head">
    <h1 class="page-title">Posts</h1>
    <p class="page-intro">
      {posts.length} deep dives and counting — databases, compilers, git internals
      and whatever else I fell down a rabbit hole on. Filter by tag, or just start
      scrolling.
    </p>
  </div>

  <div class="filter-row">
    <a class="pill active" href="/blog">all posts</a>
    {
      tags.map((tag) => (
        <a class="pill" href={`/blog/tags/${tag}`}>
          #{tag}
        </a>
      ))
    }
  </div>

  {
    years.map((year) => (
      <>
        <div class="year">{year}</div>
        <div class="card-list">
          {postsMap[year].map((post) => (
            <PostCard entry={post} />
          ))}
        </div>
      </>
    ))
  }
</Layout>
