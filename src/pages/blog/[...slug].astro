---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import {
  readingTime,
  shouldRenderPage,
  shouldListPage,
  iconForSocial,
  displayViews,
} from "@lib/utils";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Giscus from "@components/Giscus.astro";
import Aside from "@components/Aside.astro";

export async function getStaticPaths() {
  // Draft posts are excluded, but archived posts are included - they're just not
  // listed.
  const posts = (await getCollection("blog"))
    .filter(shouldRenderPage)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const posts = (await getCollection("blog"))
  .filter(shouldListPage)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

function getNextPost() {
  const postIndex = posts.findIndex((post) => post.slug === Astro.params.slug);
  return posts[postIndex + 1];
}

function getPrevPost() {
  const postIndex = posts.findIndex((post) => post.slug === Astro.params.slug);
  return posts[postIndex - 1];
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

const post = Astro.props;
const { Content, headings } = await post.render();
const tags = post.data.tags ?? [];
const socials = post.data.socials ?? [];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  route={`${post.collection}/${post.id}`}
  article={{
    title: post.data.title,
    publishedDate: post.data.date,
    updatedDate: post.data.updated,
    tags: post.data.tags,
  }}
>
  <a class="backlink" href="/blog">‹ Back to blog</a>

  <article>
    <div class="article-head">
      <div class="article-meta">
        <span><FormattedDate date={post.data.date} /></span>
        <span class="sep">·</span>
        <span>{readingTime(post.body)}</span>
        <span class="sep">·</span>
        <span>{displayViews(post)} views</span>
      </div>
      <h1>{post.data.title}</h1>
      <div class="article-tags">
        {tags.map((tag) => <a href={`/blog/tags/${tag}`}>#{tag}</a>)}
        {
          socials.length > 0 && (
            <>
              {tags.length > 0 && (
                <span class="repo" style="color:var(--dim)">
                  ·
                </span>
              )}
              <span class="repo">Discuss on</span>
              {socials.toSorted().map((social) => (
                <a
                  class="repo discuss-link"
                  href={social}
                  target="_blank"
                  rel="noopener"
                  aria-label="Discuss"
                >
                  <span set:html={iconForSocial(social)} />
                </a>
              ))}
            </>
          )
        }
      </div>
    </div>

    {headings.length > 0 && <TableOfContents headings={headings} />}

    <div class="article">
      <Content components={{ Aside }} />
    </div>

    <div class="article-foot">
      <div class="article-tags">
        {tags.map((tag) => <a href={`/blog/tags/${tag}`}>#{tag}</a>)}
      </div>
      <PostNavigation prevPost={prevPost} nextPost={nextPost} />
    </div>

    <section class="comments">
      <h3>Comments</h3>
      <Giscus />
    </section>
  </article>
</Layout>
